# --- SENTINEL AUTHORITY KEYS ---
# Copy this file to .env and fill in your values.
# setup.sh will create this file automatically on first run.

# Telegram Bot Token (from @BotFather)
# Required for remote governance via Telegram (command approvals, alerts)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Telegram Chat ID (from @userinfobot)
# The chat that receives security alerts and can approve/deny agent commands
TELEGRAM_CHAT_ID=your_chat_id_here

# Sentinel Pairing Key (auto-generated by setup.sh)
# Used to derive the AES-256-GCM master key for encrypting the secret mesh
# Generate with: openssl rand -hex 16
SENTINEL_PAIRING_KEY=change_me_before_first_run

# --- OPTIONAL: Override default DB path ---
# SENTINEL_DB_PATH=sentinel.db

# --- OPTIONAL: Override env file path ---
# SENTINEL_ENV_PATH=.env

# --- AGENT-SPECIFIC KEYS (optional) ---
# Create .env-<agent> files (e.g. .env-openclaw) with per-agent API keys.
# Sentinel will use these before falling back to global environment vars.
#
# Example .env-openclaw:
#   OPENAI_API_KEY=sk-...
#   OPENROUTER_API_KEY=sk-or-v1-...
